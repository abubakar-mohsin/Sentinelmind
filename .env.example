# SentinelMind — Environment Variables Template
# Copy this file to .env and fill in your real keys.
# The .env file is gitignored and never committed.
#
# Usage:
#   cp .env.example .env
#   (edit .env with your real keys)
#   docker compose up --build

# ─────────────────────────────────────────────────────────────────────────────
# Groq API Key — enables real AI reasoning in the dashboard
# Free key at: https://console.groq.com  (sign up → API Keys → Create API Key)
# Model used: llama-3.3-70b-versatile (fast, free tier)
# Without this key: system falls back to rule-based logic automatically (demo still works)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# VirusTotal API Key — enables real threat intelligence lookups
# Free key at: https://www.virustotal.com/gui/my-apikey
# Only active when SPRING_PROFILES_ACTIVE=real in docker-compose.yml
# ─────────────────────────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# LLM API Key (generic — used by LlmApiClient if applicable)
# Leave as-is unless you have a separate LLM integration
# ─────────────────────────────────────────────────────────────────────────────
LLM_API_KEY=not-set
